# ===== Dataset & hasil besar (tidak untuk git) =====
/data/
/train model/
/wheels/

# ===== Dependensi / model vendor (di-clone terpisah) =====
/vendor/
/.venv/
/.venv-mowa/
/.venv-yolo/
**/.venv/

# ===== Bobot & checkpoint model =====
*.pt
*.pth
*.onnx
*.engine
*.whl

# ===== Paper referensi (PDF, bukan output proyek) =====
configs/*.pdf
/papers/
*.pdf

# ===== Data turunan besar (regenerasi via pipeline; jangan commit) =====
/features/
# report CSV besar (ratusan MB); simpan hanya ringkasan kecil di whitelist bawah
reports/anomalies_consensus.csv
reports/anomalies_individual.csv
reports/overlays/
reports/plots/
reports/_ultra_val/
# Panel A/B/B' per-gambar (~728MB, regenerasi via compare_condition_panels.py);
# hanya simpan *_summary_grid.png + run.log di top-level folder ini
/reports/condition_panels/*/
# Output eksperimen MOWA v2 (regenerasi via skrip src/ baru; jangan commit yang berat)
/reports/bbox_integrity/
/reports/bbox_integrity_panels/
/reports/straightness/
/data/rectified/
/data/enhanced/
/data/augmented/

# ===== Cache Python =====
__pycache__/
*.pyc
*.pyo

# ===== Tooling lokal =====
.claude/
.ultralytics/
reports/_ultra_val/

# ===== Log / PID sementara =====
finetune_out.log
finetune_err.log
finetune.pid
*.tmp

# ===== OS =====
Thumbs.db
.DS_Store

# Whitelist ringkasan kecil (angka kunci), tetap abaikan CSV/PNG berat di dalamnya
!/reports/bbox_integrity/bbox_integrity_summary.json
!/reports/straightness/*_summary.json
